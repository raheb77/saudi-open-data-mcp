# Container-first internal serving defaults.
# Base URL overrides remain explicitly source-specific in the current runtime.
# For source-tree local development, you can usually omit the path overrides
# and let the repo-anchored `.local/` defaults apply instead.
# REGISTRY_PATH and SNAPSHOT_DIR should use durable storage in internal serving.
# CACHE_DIR is recreatable scratch space.
# Logs, observability counters, and in-memory limiter state remain process-local.
SAMA_BASE_URL=https://www.sama.gov.sa
STATS_GOV_SA_BASE_URL=https://www.stats.gov.sa
DATA_GOV_SA_BASE_URL=https://open.data.gov.sa
MOF_BASE_URL=https://www.mof.gov.sa
REGISTRY_PATH=/var/lib/saudi-open-data-mcp/registry.sqlite
SNAPSHOT_DIR=/var/lib/saudi-open-data-mcp/snapshots
CACHE_DIR=/var/lib/saudi-open-data-mcp/cache
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
HTTP_AUTH_TOKEN=change-me-internal-token
HTTP_AUTH_ROLE=operator
HTTP_AUTH_CAPABILITIES=read,refresh,materialize
TIER_A_REFRESH_ENABLED=false
TIER_A_REFRESH_INTERVAL_SECONDS=3600
LOG_LEVEL=INFO
